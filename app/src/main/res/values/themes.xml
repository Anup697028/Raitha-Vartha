<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.RaithaVartha" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">#388E3C</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_green</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="materialCardViewStyle">@style/Widget.RaithaVartha.CardView</item>
    </style>

    <style name="Widget.RaithaVartha.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>
